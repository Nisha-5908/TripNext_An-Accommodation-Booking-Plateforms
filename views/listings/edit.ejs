<%- layout ("/layouts/boilerplate") -%>
  <div class="row mt-3">
    <div class="col-8 offset-2">

      <h1>Edit your Listings</h1>
      <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation"
        enctype="multipart/form-data">
        <div class="mb-3">
          <lable for="title" class="form-lable">Title</lable>
          <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control" required>
          <div class="invalid-feedback">Title should be correct</div>

        </div>

        <div class="mb-3">
          <lable for="description" class="form-lable">Description</lable>
          <textarea name="listing[description]" type="text" class="form-control"
            required><%= listing.description %></textarea>
          <div class="invalid-feedback">discriptions shoulds be valid </div>
        </div>

        <div class="mb-3">
          Original Listing Image<br />
          <img src="<%= originalImageUrl %>" alt="listing_image" style="width: 250px; max-height: 300px; object-fit: cover; border-radius: 8px;" />
        </div>


        <div class="mb-3">
          <lable for="image(url)" class="form-lable">Upload New Image</lable>
          <input name="listing[image]" type="file" class="form-control">
        </div>

        <div class="row">
          <div class="mb-3 col-md-4">
            <lable for="price" class="form-lable">Price</lable>
            <input name="listing[price]" value="<%= listing.price %>" class="form-control" required>
            <div class="invalid-feedback">Please enter the valid price </div>
          </div>

          <div class="mb-3 col-md-8">
            <lable for="country" class="form-lable">Country</lable>
            <input name="listing[country]" value="<%= listing.country %>" type="text" class="form-control" required>
            <div class="invalid-feedback">Please enter the valid country </div>
          </div>
        </div>

        <div class="mp-3">
          <lable for="location" class="form-lable">Location</lable>
          <input name="listing[location]" value="<%= listing.location %>" type="text" class="form-control" required>
          <div class="invalid-feedback">Please enter the valid location </div>
        </div>


        <button class="btn btn-dark edit-btn mt-3">Edit</button>
        <br /><br />
      </form>
    </div>
  </div>