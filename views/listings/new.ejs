 <% layout("/layouts/boilerplate") %>
 <div class="row">
    <div class="col-8 offset-2">
<br />
    <h3>Create a New Listings</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

        <div class="mb-3">
           <lable for="title" class="form-lable">Title</lable>
           <input name="listing[title]" placeholder="Enter chachy title" type="text" class="form-control" required>
           <div class="invalid-feedback"> Please enter the valid title</div>
        </div>

        <div class="mb-3">
          <lable for="description" class="form-lable">Description</lable>
          <textarea name="listing[description]" placeholder="Enter Description" class="form-control" required></textarea>
          <div class="invalid-feedback">Please enter a short discription</div>
        </div>

        <!-- <div class="mb-3">
         <lable for="image" class="form-lable">Image URL</lable>
         <input name="listing[image]" placeholder="enter image URL" type="text" class="form-control" required>
         <div class="invalid-feedback">Please enter the valid url </div>
        </div> -->


        <div class="mb-3">
         <lable for="image" class="form-lable">Upload Listing image </lable>
         <input name="listing[image]" type="file" class="form-control" required>
         <div class="invalid-feedback"></div>
        </div>

         <div class="row">
        <div class="mb-3 col-md-4" >
          <lable for="price" class="form-lable">Price</lable>
          <input name="listing[price]" placeholder="1200" class="form-control" required>
           <div class="invalid-feedback">Please enter the valid price </div>
        </div>
        <div class="mb-3 col-md-8">
            <lable for="country" class="form-lable">Country</lable>
            <input name="listing[country]" placeholder="INDIA" type="text" class="form-control" required>
             <div class="invalid-feedback">Please enter valid country Name</div>
        </div>
       </div>

        <div class="mb-3">
             <lable for="location" class="form-lable">location</lable>
             <input name="listing[location]" placeholder="Uttar Pradesh" type="text" class="form-control" required>
              <div class="invalid-feedback">Please enter the valid-location</div>
        </div>
        <button class="btn btn-dark add-btn">Add</button>
        <br /><br />
    </form>
    </div>
</div>
